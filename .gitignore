# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store

# user uploaded files
/public/uploads/

# tmp / cache
/.tmp/

# ===== 数据库文件 =====
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

# ===== 数据库备份文件 =====
*.db.bak
*.db.bak-*
*.sqlite.bak
dev.db*
*.db-backup

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ===== 本地开发环境文件 =====
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
.env*

# ===== 敏感配置 =====
*.pem
*.key
*.p12
secrets/
credentials/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma client 为生成代码，不入库；装包时由 postinstall (prisma generate) 自动重建
/src/generated/
