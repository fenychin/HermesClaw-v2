# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
**/.next/
**/out/

# production
/build

# misc
.DS_Store
*.pem
HermesClaw_VibeCoding_Prompts.md

# user uploaded files
/public/uploads/

# tmp / cache
/.tmp/
dev.db
dev.db-journal

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.env.local
.env.production
.env.test.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma client 为生成代码，不入库；装包时由 postinstall (prisma generate) 自动重建
/src/generated/
**/src/generated/

# monorepo 包构建产物（由 pnpm build 自动重建）
packages/*/dist/
apps/*/.next/
apps/*/dist/

# turborepo 缓存
.turbo/
**/.turbo/

# 数据库文件（严禁提交）
*.db
*.db.bak
*.db.bak-*
*.sqlite
*.sqlite3
dev.db*
prisma/*.db
prisma/.db-

# HermesClaw — AI agent artifacts & temp files (auto-generated, do not commit)
.claude-test-output.log
*.log
tmp-*.ts
tmp-*.js
*.bak
*.tmp
scripts/migrate-once/
