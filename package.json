{
  "name": "hermesclaw-v2",
  "version": "3.00.00",
  "packageManager": "pnpm@11.5.2",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:sandbox": "cd apps/web && tsx --tsconfig tsconfig.json src/lib/server/sandbox/server.ts",
    "dev:all": "concurrently -n web,sandbox -c cyan,green \"pnpm dev\" \"pnpm dev:sandbox\"",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo run test",
    "test:kernel": "vitest run --project '@hermesclaw/hermes-kernel'",
    "test:e2e": "vitest run --project '@hermesclaw/web' --reporter=verbose",
    "test:smoke": "vitest run apps/web/src/test/e2e/foreign-trade-smoke.test.ts",
    "test:boundary": "vitest run --project '@hermesclaw/web' -t \"boundary|Boundary|Cross-Tenant\"",
    "lint:domains": "eslint packages",
    "check:boundaries": "pnpm -w lint:domains && echo '✅ 三域边界检查通过'"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "turbo": "latest",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "better-sqlite3",
      "prisma",
      "esbuild"
    ]
  }
}
