{
  "name": "hermesclaw-v2",
  "version": "3.00.00",
  "packageManager": "pnpm@11.5.2",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "lint:domains": "eslint packages",
    "check:boundaries": "pnpm -w lint:domains && echo '✅ 三域边界检查通过'"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "turbo": "latest"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "better-sqlite3",
      "prisma",
      "esbuild"
    ]
  }
}
