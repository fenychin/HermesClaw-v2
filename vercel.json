{
  "functions": {
    "src/app/api/cron/**/*": {
      "maxDuration": 300
    },
    "src/app/api/**/*": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/harness/cron",
      "schedule": "0 3 */3 * *"
    },
    {
      "path": "/api/maintenance/cleanup",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/canary-eval",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/capability-health",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/workflow-timeout",
      "schedule": "*/5 * * * *"
    }
  ]
}
