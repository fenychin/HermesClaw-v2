{
  "name": "@hermesclaw/industry-pack-sdk",
  "version": "0.1.0",
  "private": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./output-extractors": {
      "types": "./dist/output-extractors.d.ts",
      "import": "./dist/output-extractors.mjs",
      "require": "./dist/output-extractors.js"
    },
    "./types": {
