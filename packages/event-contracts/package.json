{
  "name": "@hermesclaw/event-contracts",
  "version": "0.12.17",
  "private": true,
  "description": "HermesClaw runtime event contracts (TaskEnvelope / ExecutionEvent / ActionReceipt / ExecutionSummary / CapabilityRegistration / ConnectorLease / HumanApprovalCheckpoint / BoundaryDecision / TaskPayloads).",
  "type": "module",
  "main": "./src/index.ts",
