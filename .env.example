# Anthropic Claude API 密钥
ANTHROPIC_API_KEY=
# DeepSeek API 密钥
DEEPSEEK_API_KEY=
# OpenAI API 密钥
OPENAI_API_KEY=
# Google Gemini API 密钥
GOOGLE_API_KEY=
# MiniMax API 密钥
MINIMAX_API_KEY=

# ─────────────── Runtime Mode 统一开关（CLAUDE.md §6 + 全局架构审查 P1-#6） ─────────────── #
# 三态优先级（仅当显式设置 true/false 时才覆盖开发默认 mock）：
#   true  = 强制 mock（不发起 HTTP）
#   false = 强制真实（即使是开发环境）
#   不设置 = NODE_ENV==='development' 时默认 mock，其他环境默认真实
HERMES_USE_MOCK=
OPENCLAW_USE_MOCK=
# 工作流引擎路由：local（本地 DAG）/ hermes（远端 Hermes API）
# 开发环境默认 local，生产环境默认 hermes
WORKFLOW_ROUTING_MODE=

# ─────────────── Harness / 数据库 / 基础环境 ─────────────── #
# Harness 评估引擎 LLM Provider（留空=自动：有 ANTHROPIC_API_KEY 用 Anthropic，否则 DeepSeek）
# 可选值：anthropic | deepseek（用于在已注入某 key 时强制指定路径）
HARNESS_LLM_PROVIDER=
# 数据库连接
DATABASE_URL=
# 管理员密码
ADMIN_PASSWORD=
# NextAuth Secret
AUTH_SECRET=
# NextAuth URL
AUTH_URL=
# Harness 定时任务保护密钥（配置后 /api/harness/cron 须带 Authorization: Bearer <值>）
CRON_SECRET=
# Harness 评估窗口（小时），默认 72，本地测试时可设为 1
EVAL_WINDOW_HOURS=72

# 应用元信息
NEXT_PUBLIC_APP_NAME=HermesClaw-v2
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 移动端 PWA 预览开关（PRD §9.3 暂缓项；非 true 时 (mobile)/* 路由返回 404）
NEXT_PUBLIC_ENABLE_MOBILE_PREVIEW=false

# 系统级评估默认工作空间 ID（在无用户上下文的定时任务/内部系统调用中，限制数据操作在安全边界内）
DEFAULT_WORKSPACE_ID=default

# L4（全自主）自动化等级白名单（AGENTS.md §4.7 / §5.2）
# —— 仅在经过安全评估后填写允许的 workspace ID（逗号分隔）。
# —— 未配置或未列入的工作区，无论是否通过 Harness 提案审批，一律不允许使用 L4。
L4_ALLOWED_WORKSPACES=
